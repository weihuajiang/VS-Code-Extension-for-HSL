{  "keywords": [
    "Keyword",
    "activity",
    "actionblock",
    "executoronly",
    "oncancelaction",
    "oncanceltask",
    "resource",
    "reschedule",
    "schedule",
    "scheduleronly",
    "schedulerprompt",
    "workflow",
    "debug",
    "echo",
    "__filename__"
  ],  "comments": {
    "lineComment": "//",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "/*", "close": "*/" }
  ],
  "surroundingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "folding": {
    "markers": {
      "start": "^\\s*//\\s*#?region\\b",
      "end": "^\\s*//\\s*#?endregion\\b"
    }
  }
}
