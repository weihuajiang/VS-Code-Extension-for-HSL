{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "HSL",
  "scopeName": "source.hsl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#preprocessor" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#typesAndConstants" },
    { "include": "#namespaces" },
    { "include": "#functionDecl" },
    { "include": "#methodDecl" },
    { "include": "#callsAndBuiltins" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.hsl", "match": "//.*$" },
        {
          "name": "comment.block.hsl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "preprocessor": {
      "patterns": [
        {
          "name": "keyword.control.preprocessor.hsl",
          "match": "^\\s*#\\s*(include|ifndef|ifdef|endif|define|pragma)\\b"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.hsl",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.hsl", "match": "\\\\." }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hsl", "match": "\\b\\d+(\\.\\d+)?\\b" }
      ]
    },

    "keywords": {
      "patterns": [
        {
          "name": "keyword.scheduler.hsl",
          "match": "\\b(activity|actionblock|executoronly|oncancelaction|oncanceltask|resource|reschedule|schedule|scheduleronly|schedulerprompt|workflow)\\b"
        },
        {
          "name": "keyword.control.hsl",
          "match": "\\b(if|else|for|while|break|return|goto|abort|resume|loop|next|pause|onerror|lock|unlock)\\b"
        },
        {
          "name": "storage.type.hsl",
          "match": "\\b(variable|string|sequence|device|resource|dialog|object|timer|event|file|char|short|long|float|void)\\b"
        },
        {
          "name": "storage.modifier.hsl",
          "match": "\\b(private|static|const|global|synchronized)\\b"
        },
        {
          "name": "keyword.declaration.hsl",
          "match": "\\b(namespace|function|method|struct)\\b"
        },
        {
          "name": "keyword.directive.hsl",
          "match": "\\b(debug|echo)\\b"
        },
        {
          "name": "keyword.other.hsl",
          "match": "\\b(__filename__|error)\\b"
        }
      ]
    },
    
    "typesAndConstants": {
      "patterns": [
        {
          "name": "constant.language.boolean.hsl",
          "match": "\\b(hslTrue|hslFalse)\\b"
        },
        {
          "name": "constant.language.hsl",
          "match": "\\b(hslInfinite|hslInteger|hslFloat|hslString|hslDate|hslOKOnly|hslOKCancel|hslAbortRetryIgnore|hslYesNoCancel|hslYesNo|hslRetryCancel|hslOK|hslCancel|hslAbort|hslRetry|hslIgnore|hslYes|hslNo|hslError|hslQuestion|hslExclamation|hslInformation|hslDefButton1|hslDefButton2|hslDefButton3|hslRead|hslWrite|hslAppend|hslCSVDelimited|hslTabDelimited|hslFixedLength|hslAsciiText|hslCurrent|hslFirst|hslLast|hslBegin|hslEnd|hslHide|hslShow|hslShowMaximized|hslShowMinimized|hslSynchronous|hslAsynchronous|hslNoParity|hslOddParity|hslEvenParity|hslMarkParity|hslSpaceParity|hslOneStopBit|hslOne5StopBits|hslTwoStopBits|hslNoHandshaking|hslXonXoff|hslRequestToSend|hslRequestToSendXonXoff|hslBinaryMode|hslASCIIMode|hslStoppable|hslNotStoppable|hslTimerExpired|hslTimerStopped|hslSoundAlias|hslSoundFileName|hslByLabwareId|hslByPositionId|hslWhite|hslBlack|hslDarkGray|hslGray|hslRed|hslDarkRed|hslYellow|hslDarkYellow|hslGreen|hslDarkGreen|hslCyan|hslDarkCyan|hslBlue|hslDarkBlue|hslMagenta|hslDarkMagenta|hslSchedulingStart|hslLatestTaskStart|hslLatestTaskEnd|hslUseDefault|HSL_RUNTIME|HSL_SCHEDULE|HSL_ACTION_METHOD)\\b"
        },
        {
          "name": "variable.other.member.hsl",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\[\\])"
        },
        {
          "name": "keyword.operator.runtime-parse.hsl",
          "match": "<<"
        },
        {
          "name": "keyword.operator.hsl",
          "match": "(==|!=|<=|>=|=|<|>|\\+\\+|--|\\+|-|\\*|/|%|\\^|&&|\\|\\||&|\\||!|::|\\.)"
        }
      ]
    },

    "namespaces": {
      "patterns": [
        {
          "name": "entity.name.namespace.hsl",
          "match": "\\bnamespace\\s+([A-Za-z_][A-Za-z0-9_:]*)\\b"
        },
        {
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*::\\s*([A-Za-z_][A-Za-z0-9_:]*)\\b",
          "captures": {
            "1": { "name": "entity.name.namespace.hsl" },
            "2": { "name": "entity.name.other.hsl" }
          }
        }
      ]
    },

    "functionDecl": {
      "patterns": [
        {
          "name": "meta.function.declaration.hsl",
          "match": "\\bfunction\\s+((?:[A-Za-z_][A-Za-z0-9_]*::)*[A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.function.hsl" }
          }
        }
      ]
    },

    "methodDecl": {
      "patterns": [
        {
          "name": "meta.method.declaration.hsl",
          "match": "\\bmethod\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "entity.name.function.hsl" }
          }
        }
      ]
    },

    "callsAndBuiltins": {
      "patterns": [
        {
          "name": "support.function.builtin.hsl",
          "match": "\\b(Sin|Cos|Tan|ASin|ACos|ATan|Exp|Log|Log10|Ceiling|Floor|IStr|FStr|IVal|IVal2|FVal|FVal2|Trace|FormatTrace|InputBox|MessageBox|Shell|Fork|Join|GetBarcodeJoker|GetType|GetTime|GetDate|GetMethodFileName|GetFileName|GetFunctionName|GetLineNumber|GetRowNumber|GetColumnNumber|GetBinPath|GetConfigPath|GetLabwarePath|GetLibraryPath|GetMethodsPath|GetLogFilesPath|GetSystemPath|GetLanguage|GetIVDSystem|GetUniqueRunId|GetHWnd|SearchPath|AlignSequences|GetUserName|AddCheckSum|VerifyCheckSum|RegisterAbortHandler|UnregisterAbortHandler|GetVectorDbTrackerObject|GetSimulationMode|GetTimeScaleFactor|SetTimeScaleFactor|IsDBNull|SetDBNull|GetCommState|SetCommState|GetCommTimeouts|SetCommTimeouts|Translate|GetDeviceRef|RegisterMethod|ActivateAt|ActivateDelay|ActivateAfter|ActivateBefore|GetTaskIds|GetCurrentTaskId|GetCurrentTaskViewName|GetTaskViewName|GetMethodViewName|GetCurrentActivityViewName|GetCurrentActivityDuration|GetCurrentActivityPlannedDuration|GetCancelledActivityViewName|GetWorkflowFileName|TaskIsCancelable|CancelTask|TaskIsUnschedulable|UnscheduleTask|GetTaskStatus|GetTaskCancelReason|ValidateTaskResources|GetMethodProperties|SetMethodProperties|SetTaskProperties|SetTaskViewName|EnableReschedule|DisableReschedule|RescheduleIsEnabled|GetSchedulerSettings|SetSchedulerSettings|GetSchedulerSettings2|SetSchedulerSettings2|GetRunState|SetTaskDescription|SetCurrentActivityDescription|GetEstimatedActivityDuration|ResetActivityDurationLog|PreActivity|PostActivity)\\b"
        },
        {
          "name": "support.function.builtin.hsl",
          "match": "\\b(err\\.Raise)\\b"
        },
        {
          "name": "support.function.builtin.hsl",
          "match": "\\b(GetSize|SetSize|AddAsLast|GetAt|SetAt|ElementAt|InsertElementAt|RemoveElementAt|CreateObject|ReleaseObject)\\b"
        },
        {
          "name": "entity.name.function.call.hsl",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
