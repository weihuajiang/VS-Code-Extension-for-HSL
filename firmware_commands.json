          "description": "Barcode types bitmask"
        },
        {
          "name": "mq",
          "type": "HEX",
          "min": 0,
          "max": 255,
          "default": 0,
          "width": 2,
          "description": "2D code types bitmask (2D Autoload only)"
        },
        {
          "name": "mb",
          "type": "INT",
          "min": 1,
          "max": 10,
          "default": 1,
          "width": 4,
          "description": "Max codes per image (2D Autoload only)"
        },
        {
          "name": "mo",
          "type": "INT",
          "min": 0,
          "max": 999,
          "default": 0,
          "width": 3,
          "description": "Illumination settings (2D Autoload only)"
        }
      ],
      "responseFields": ["id####", "er##/##"],
      "notes": ""
    },
    {
      "code": "DB",
      "sfcoId": "",
