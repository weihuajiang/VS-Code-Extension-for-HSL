      "commandPoint": 1,
      "params": [
        {
          "name": "id",
          "type": "INT",
          "min": 0,
          "max": 9999,
          "default": 0,
          "width": 4,
          "description": "Identification number"
        }
      ],
      "responseFields": ["id####", "er##/##", "cd**************"],
      "notes": "Bit pattern: bit 54 (MSB) = position 55, bit 0 (LSB) = position 1"
    },
    {
      "code": "CB",
      "sfcoId": "SFCO.0072",
      "category": "Autoload Carrier Handling",
