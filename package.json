{
  "name": "hsl-language-support",
  "displayName": "HSL (Hamilton) Language Support",
  "description": "Base language support for Hamilton Standard Language (HSL)",
  "version": "1.8.3",
  "publisher": "ZacharyMilot",
  "author": "Zachary Milot",
  "repository": {
    "type": "git",
    "url": "https://github.com/zdmilot/VS-Code-Extension-for-HSL.git"
  },
  "bugs": {
    "url": "https://github.com/zdmilot/VS-Code-Extension-for-HSL/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Linters", "Other"],
  "icon": "HSL.png",
  "main": "./out/extension.js",
  "activationEvents": ["onLanguage:hsl"],
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "hsl",
        "aliases": ["HSL", "Hamilton Standard Language"],
        "extensions": [".hsl", ".hs_", ".sub"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hsl",
        "scopeName": "source.hsl",
        "path": "./syntaxes/hsl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "hsl",
        "path": "./snippets/hsl.code-snippets"
      }
    ]
  }
}
